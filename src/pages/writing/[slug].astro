---
import { getCollection, getEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const articles = await getCollection("writing");
  return articles.map((article) => ({
    params: { slug: article.slug },
  }));
}

const { slug } = Astro.params;
const article = await getEntry("writing", slug);
if (!article) return Astro.redirect("/writing");

const { Content } = await article.render();

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<BaseLayout
  title={`${article.data.title} — Cristobal Graña Samanez`}
  description={article.data.description}
  ogTitle={article.data.title}
  fadeOnly
>
  <header class="header">
    <a href="/writing" class="back-link animate-fade-in-up" aria-label="Go back">
      <svg
        class="back-arrow"
        width="16"
        height="16"
        viewBox="0 0 20 20"
        fill="none"
        aria-hidden="true"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          d="M16 10H4M4 10L9 5M4 10L9 15"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
      <span class="back-text">Back</span>
    </a>
  </header>

  <main class="main">
    <article class="article animate-fade-in-up animate-delay-1">
      <div class="article-title">
        <h2 class="article-heading">{article.data.title}</h2>
        <p class="article-meta">
          <span class="article-date">{formatDate(article.data.date)}</span>
        </p>
      </div>
      <div class="prose">
        <Content />
      </div>
    </article>
  </main>
</BaseLayout>

<style>
  .article-heading {
    font-size: 22px;
    font-weight: 400;
    color: #ffffff;
    line-height: 1.3;
    margin-bottom: 12px;
  }

  .article-meta {
    display: flex;
    gap: 16px;
    align-items: center;
    font-size: 14px;
    color: #838383;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: #888888;
    font-size: 14px;
    line-height: 1;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .back-link:hover {
    color: #ffffff;
  }

  .back-arrow {
    display: block;
    flex-shrink: 0;
    margin-top: -2px;
  }

  .back-text {
    text-decoration: underline;
    text-decoration-color: #444444;
    text-underline-offset: 3px;
    transition: text-decoration-color 0.2s ease;
  }

  .back-link:hover .back-text {
    text-decoration-color: #838383;
  }

  .article-date {
    color: #838383;
  }

  .prose {
    font-size: 16px;
    color: #9b9b9b;
    line-height: 1.7;
  }

  .prose :global(p) {
    margin-bottom: 24px;
  }

  .prose :global(p:last-child) {
    margin-bottom: 0;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid #333333;
    margin: 40px 0;
  }

  .prose :global(em) {
    color: #bbbbbb;
    font-style: italic;
  }

  .prose :global(a) {
    color: #ffffff;
    text-decoration: underline;
    text-decoration-color: #838383;
    text-underline-offset: 3px;
    transition: text-decoration-color 0.2s ease;
  }

  .prose :global(a:hover) {
    text-decoration-color: #ffffff;
  }

  .prose :global(strong) {
    color: #cccccc;
    font-weight: 400;
  }

  .prose :global(blockquote) {
    margin: 0 0 24px;
    padding: 4px 0 4px 20px;
    border-left: 2px solid #444444;
    color: #bbbbbb;
    font-style: italic;
  }

  .prose :global(blockquote p:last-child) {
    margin-bottom: 0;
  }

  .prose :global(figure) {
    margin: 40px 0;
  }

  .prose :global(img) {
    display: block;
    width: 100%;
    height: auto;
    background-color: #292929;
    border-radius: 16px;
  }

  .prose :global(figcaption) {
    margin-top: 12px;
    font-size: 14px;
    color: #838383;
    text-align: center;
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    const back = document.querySelector(".back-link");
    back?.addEventListener("click", (e) => {
      // Go to the previous page if there is one, otherwise follow the href.
      if (window.history.length > 1) {
        e.preventDefault();
        window.history.back();
      }
    });
  });
</script>
