---
import { getCollection, getEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const articles = await getCollection("writing");
  return articles.map((article) => ({
    params: { slug: article.slug },
  }));
}

const { slug } = Astro.params;
const article = await getEntry("writing", slug);
if (!article) return Astro.redirect("/writing");

const { Content } = await article.render();

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<BaseLayout
  title={`${article.data.title} — Cristobal Graña Samanez`}
  description={article.data.description}
  ogTitle={article.data.title}
>
  <header class="header">
    <h1 class="name animate-fade-in-up">
      <a href="/" class="name-link">Cristobal Graña Samanez</a>
    </h1>
    <p class="title animate-fade-in-up animate-delay-1">
      Design Technologist, interaction engineer
    </p>
  </header>

  <main class="main">
    <article class="article animate-fade-in-up animate-delay-3">
      <div class="article-title">
        <h2 class="article-heading">{article.data.title}</h2>
        <p class="article-meta">
          <a href="/writing" class="back-link">Writing</a>
          <span class="article-date">{formatDate(article.data.date)}</span>
        </p>
      </div>
      <div class="prose">
        <Content />
      </div>
    </article>
  </main>
</BaseLayout>

<style>
  .name-link {
    color: inherit;
    text-decoration: none;
  }

  .article-heading {
    font-size: 22px;
    font-weight: 400;
    color: #ffffff;
    line-height: 1.3;
    margin-bottom: 12px;
  }

  .article-meta {
    display: flex;
    gap: 16px;
    align-items: center;
    font-size: 14px;
    color: #666666;
  }

  .back-link {
    color: #888888;
    text-decoration: underline;
    text-decoration-color: #444444;
    text-underline-offset: 3px;
    transition: color 0.2s ease, text-decoration-color 0.2s ease;
  }

  .back-link:hover {
    color: #ffffff;
    text-decoration-color: #666666;
  }

  .article-date {
    color: #666666;
  }

  .prose {
    font-size: 16px;
    color: #9b9b9b;
    line-height: 1.7;
  }

  .prose :global(p) {
    margin-bottom: 24px;
  }

  .prose :global(p:last-child) {
    margin-bottom: 0;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid #333333;
    margin: 40px 0;
  }

  .prose :global(em) {
    color: #bbbbbb;
    font-style: italic;
  }

  .prose :global(a) {
    color: #ffffff;
    text-decoration: underline;
    text-decoration-color: #666666;
    text-underline-offset: 3px;
    transition: text-decoration-color 0.2s ease;
  }

  .prose :global(a:hover) {
    text-decoration-color: #ffffff;
  }

  .prose :global(strong) {
    color: #cccccc;
    font-weight: 400;
  }
</style>
