---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="PolyVane Dashboard - Cristobal Graña Samanez"
  ogTitle="PolyVane Dashboard"
  ogUrl="https://cristobalgrana.me/polyvane/"
>
  <main class="main polyvane-placeholder">
    <p class="polyvane-placeholder-text animate-fade-in-up">
      PolyVane Dashboard — Coming Soon
    </p>
  </main>
</BaseLayout>

<style>
  .polyvane-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
  }

  .polyvane-placeholder-text {
    font-size: 14px;
    color: #888888;
    text-align: center;
  }
</style>
