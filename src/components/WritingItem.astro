---
interface Props {
  href: string;
  date: string;
  title: string;
  description: string;
  delayClass: string;
}

const { href, date, title, description, delayClass } = Astro.props;
---

<a href={href} class={`today-link ${delayClass}`}>
  <div class="today-item writing-item">
    <span class="today-date">{date}</span>
    <div class="today-content writing-content">
      <h3 class="today-title">{title}</h3>
      <p class="today-subtitle writing-subtitle">{description}</p>
    </div>
    <svg
      class="arrow-icon"
      width="16"
      height="16"
      viewBox="0 0 16 16"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
    >
      <path
        d="M3 8H12.5M12.5 8L8 3.5M12.5 8L8 12.5"
        stroke="#838383"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      ></path>
    </svg>
  </div>
</a>
