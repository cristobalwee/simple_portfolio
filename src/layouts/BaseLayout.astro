---
import Footer from "../components/Footer.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  ogTitle?: string;
  ogUrl?: string;
  ogImage?: string;
}

const {
  title = "Cristobal Graña Samanez - Design Technologist",
  description = "Design Technologist & Interaction Engineer",
  ogTitle = "Cristobal Graña Samanez",
  ogUrl = "https://cristobalgrana.me/",
  ogImage = "https://cristobalgrana.me/og.jpg",
} = Astro.props;

const ogDescription = "Design Technologist, interaction engineer.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Cristobal Grana Samanez" />
    <link
      rel="preload"
      href="/HelveticaNeueLight.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />

    <!-- Open Graph / Facebook -->
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={ogUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Cristobal Graña Samanez" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@cristo_grana" />
    <meta name="twitter:creator" content="@cristo_grana" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={ogImage} />
  </head>

  <body>
    <div class="container">
      <slot />
      <Footer />
    </div>

    <script is:inline>
      function animateBioLines() {
        const bio = document.getElementById("bio");
        if (!bio) return;

        const walker = document.createTreeWalker(bio, NodeFilter.SHOW_TEXT);
        const textNodes = [];
        while (walker.nextNode()) textNodes.push(walker.currentNode);

        textNodes.forEach((node) => {
          const parts = node.textContent.split(/(\s+)/);
          const frag = document.createDocumentFragment();
          for (const part of parts) {
            if (!part) continue;
            if (/^\s+$/.test(part)) {
              frag.appendChild(document.createTextNode(" "));
            } else {
              const span = document.createElement("span");
              span.className = "bio-word";
              span.textContent = part;
              frag.appendChild(span);
            }
          }
          node.parentNode.replaceChild(frag, node);
        });

        const words = bio.querySelectorAll(".bio-word");
        const BASE_DELAY = 0.4;
        const LINE_STAGGER = 0.06;
        let lastTop = -Infinity;
        let lineIndex = -1;

        words.forEach((span) => {
          const top = span.getBoundingClientRect().top;
          if (Math.abs(top - lastTop) > 2) {
            lineIndex++;
            lastTop = top;
          }
          span.style.animationDelay =
            BASE_DELAY + lineIndex * LINE_STAGGER + "s";
        });

        const totalLinesOffset = lineIndex * LINE_STAGGER;
        document.querySelectorAll(".animate-fade-in-up").forEach((el) => {
          const match = el.className.match(/animate-delay-(\d+)/);
          if (!match) return;
          const n = parseInt(match[1], 10);
          if (n < 3) return;
          el.style.animationDelay = 0.2 + n * 0.1 + totalLinesOffset + "s";
        });
      }

      function initProjectAccordion() {
        const items = document.querySelectorAll(".project-item");

        items.forEach((item) => {
          const row = item.querySelector(".project-row");
          if (!row) return;
          row.addEventListener("click", () => {
            const isOpen = item.classList.contains("project-item--open");
            items.forEach((i) => i.classList.remove("project-item--open"));
            if (!isOpen) {
              item.classList.add("project-item--open");
            }
          });

          const carousel = item.querySelector(".project-carousel");
          const track = item.querySelector(".project-carousel-track");
          if (track && carousel) {
            const updateBlurs = () => {
              const scrollLeft = track.scrollLeft;
              const maxScroll = track.scrollWidth - track.clientWidth;
              carousel.style.setProperty(
                "--left-opacity",
                scrollLeft > 8 ? 1 : 0
              );
              carousel.style.setProperty(
                "--right-opacity",
                maxScroll - scrollLeft < 8 ? 0 : 1
              );
            };
            track.addEventListener("scroll", updateBlurs);
          }
        });
      }

      function initLightbox() {
        const carouselImages = document.querySelectorAll(
          ".project-carousel-image"
        );
        if (carouselImages.length === 0) return;

        const overlay = document.createElement("div");
        overlay.className = "lightbox-overlay";

        const closeBtn = document.createElement("button");
        closeBtn.className = "lightbox-close";
        closeBtn.type = "button";
        closeBtn.setAttribute("aria-label", "Close");
        closeBtn.innerHTML =
          '<svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M5 5L15 15M15 5L5 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>';
        overlay.appendChild(closeBtn);

        document.body.appendChild(overlay);

        let activeImg = null;
        let activeClone = null;
        let activeAnim = null;
        let activeTarget = null;
        const reduceMotion = window.matchMedia(
          "(prefers-reduced-motion: reduce)"
        ).matches;
        const duration = reduceMotion ? 0 : 600;
        const easing = "cubic-bezier(0.41,0.39,0,1.01)";

        function computeTarget(rect) {
          const aspect = rect.width / rect.height;
          const maxW = Math.min(window.innerWidth * 0.95, 1080);
          const maxH = Math.min(window.innerHeight * 0.7, 720);
          let w = maxW;
          let h = w / aspect;
          if (h > maxH) {
            h = maxH;
            w = h * aspect;
          }
          return {
            x: (window.innerWidth - w) / 2,
            y: (window.innerHeight - h) / 2,
            w,
            h,
          };
        }

        function open(img) {
          if (activeImg) return;
          activeImg = img;

          const origRect = img.getBoundingClientRect();
          const target = computeTarget(origRect);
          activeTarget = target;

          const clone = document.createElement("img");
          clone.src = img.currentSrc || img.src;
          clone.alt = img.alt;
          clone.className = "lightbox-image";
          clone.style.left = target.x + "px";
          clone.style.top = target.y + "px";
          clone.style.width = target.w + "px";
          clone.style.height = target.h + "px";
          activeClone = clone;

          const dx = origRect.left - target.x;
          const dy = origRect.top - target.y;
          const scale = origRect.width / target.w;
          const initialTransform =
            "translate(" + dx + "px, " + dy + "px) scale(" + scale + ")";

          img.style.visibility = "hidden";
          document.body.classList.add("lightbox-open");
          overlay.classList.add("lightbox-overlay--visible");
          document.body.appendChild(clone);

          activeAnim = clone.animate(
            [{ transform: initialTransform }, { transform: "none" }],
            { duration, easing, fill: "forwards" }
          );

          document.addEventListener("keydown", onKey);
        }

        function close() {
          if (!activeImg) return;
          const img = activeImg;
          const clone = activeClone;
          const target = activeTarget;

          activeImg = null;
          activeClone = null;
          activeTarget = null;

          const origRect = img.getBoundingClientRect();
          const dx = origRect.left - target.x;
          const dy = origRect.top - target.y;
          const scale = origRect.width / target.w;
          const finalTransform =
            "translate(" + dx + "px, " + dy + "px) scale(" + scale + ")";

          const fromTransform = getComputedStyle(clone).transform;
          if (activeAnim) activeAnim.cancel();

          overlay.classList.remove("lightbox-overlay--visible");

          activeAnim = clone.animate(
            [{ transform: fromTransform }, { transform: finalTransform }],
            { duration, easing, fill: "forwards" }
          );

          activeAnim.onfinish = () => {
            img.style.visibility = "";
            clone.remove();
            document.body.classList.remove("lightbox-open");
            activeAnim = null;
          };

          document.removeEventListener("keydown", onKey);
        }

        function onKey(e) {
          if (e.key === "Escape") close();
        }

        overlay.addEventListener("click", close);

        carouselImages.forEach((img) => {
          img.addEventListener("click", () => open(img));
        });
      }

      class WeatherTimeManager {
        constructor() {
          this.weatherElement = document.getElementById("weather");
          this.timeElement = document.getElementById("time");
          if (!this.weatherElement || !this.timeElement) return;
          this.city = "phoenix";
          this.state = "az";
          this.country = "us";
          this.sunEmoji = `<svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M4.69996 14.1667L4.10829 14.7584C3.95308 14.9145 3.86597 15.1258 3.86597 15.3459C3.86597 15.5661 3.95308 15.7773 4.10829 15.9334C4.26443 16.0886 4.47564 16.1757 4.69579 16.1757C4.91595 16.1757 5.12716 16.0886 5.28329 15.9334L5.87496 15.3417C6.01148 15.1823 6.08282 14.9773 6.07472 14.7675C6.06662 14.5578 5.97967 14.3589 5.83126 14.2104C5.68285 14.062 5.4839 13.9751 5.27417 13.967C5.06444 13.9589 4.85938 14.0302 4.69996 14.1667ZM4.16663 10.0001C4.16663 9.77907 4.07883 9.56711 3.92255 9.41083C3.76627 9.25455 3.55431 9.16675 3.33329 9.16675H2.49996C2.27895 9.16675 2.06698 9.25455 1.9107 9.41083C1.75442 9.56711 1.66663 9.77907 1.66663 10.0001C1.66663 10.2211 1.75442 10.4331 1.9107 10.5893C2.06698 10.7456 2.27895 10.8334 2.49996 10.8334H3.33329C3.55431 10.8334 3.76627 10.7456 3.92255 10.5893C4.07883 10.4331 4.16663 10.2211 4.16663 10.0001ZM9.99996 4.16675C10.221 4.16675 10.4329 4.07895 10.5892 3.92267C10.7455 3.76639 10.8333 3.55443 10.8333 3.33341V2.50008C10.8333 2.27907 10.7455 2.06711 10.5892 1.91083C10.4329 1.75455 10.221 1.66675 9.99996 1.66675C9.77894 1.66675 9.56698 1.75455 9.4107 1.91083C9.25442 2.06711 9.16663 2.27907 9.16663 2.50008V3.33341C9.16663 3.55443 9.25442 3.76639 9.4107 3.92267C9.56698 4.07895 9.77894 4.16675 9.99996 4.16675ZM4.69996 5.87508C4.85518 6.02904 5.06468 6.11583 5.28329 6.11675C5.39296 6.11738 5.50168 6.09636 5.60321 6.05489C5.70475 6.01342 5.79709 5.95232 5.87496 5.87508C6.03017 5.71895 6.11729 5.50774 6.11729 5.28758C6.11729 5.06743 6.03017 4.85622 5.87496 4.70008L5.28329 4.10841C5.12387 3.97189 4.91881 3.90055 4.70908 3.90866C4.49935 3.91676 4.3004 4.0037 4.15199 4.15211C4.00358 4.30052 3.91663 4.49947 3.90853 4.7092C3.90043 4.91893 3.97177 5.124 4.10829 5.28341L4.69996 5.87508ZM14.7 6.11675C14.9186 6.11583 15.1281 6.02904 15.2833 5.87508L15.875 5.28341C15.9622 5.20871 16.033 5.11678 16.0831 5.01339C16.1331 4.91 16.1612 4.79739 16.1656 4.68263C16.1701 4.56786 16.1507 4.45342 16.1088 4.34648C16.0669 4.23954 16.0034 4.