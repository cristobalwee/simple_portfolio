10.0001C14.5811 8.78518 14.0975 7.62067 13.2384 6.76161C12.3794 5.90254 11.2149 5.41895 9.99996 5.41675ZM9.99996 12.9167C9.4231 12.9167 8.85919 12.7457 8.37955 12.4252C7.8999 12.1047 7.52607 11.6492 7.30531 11.1162C7.08455 10.5833 7.02679 9.99685 7.13934 9.43107C7.25188 8.86529 7.52966 8.34559 7.93756 7.93769C8.34547 7.52978 8.86517 7.252 9.43095 7.13946C9.99672 7.02692 10.5832 7.08468 11.1161 7.30543C11.6491 7.52619 12.1046 7.90002 12.4251 8.37967C12.7456 8.85931 12.9166 9.42322 12.9166 10.0001C12.9166 10.7736 12.6093 11.5155 12.0624 12.0625C11.5154 12.6095 10.7735 12.9167 9.99996 12.9167Z" fill="#666666"/>
            </svg>`;
          this.clockEmoji = `<svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M12.3472 10.4801L10.7577 9.56272V6.21207C10.7577 6.01115 10.6778 5.81846 10.5358 5.67639C10.3937 5.53431 10.201 5.4545 10.0001 5.4545C9.79916 5.4545 9.60646 5.53431 9.46439 5.67639C9.32232 5.81846 9.2425 6.01115 9.2425 6.21207V9.99995C9.24247 10.133 9.27745 10.2636 9.34395 10.3788C9.41044 10.494 9.5061 10.5897 9.62129 10.6562L11.5896 11.7925C11.6758 11.8423 11.7709 11.8747 11.8696 11.8877C11.9683 11.9007 12.0685 11.8942 12.1647 11.8684C12.2608 11.8427 12.351 11.7982 12.4299 11.7376C12.5089 11.6771 12.5752 11.6015 12.6249 11.5153C12.6747 11.4291 12.707 11.3339 12.7199 11.2352C12.7329 11.1366 12.7263 11.0363 12.7005 10.9401C12.6747 10.844 12.6302 10.7539 12.5696 10.675C12.509 10.596 12.4334 10.5298 12.3472 10.4801V10.4801ZM10.0001 2.42419C8.50173 2.42419 7.03704 2.8685 5.79121 3.70094C4.54538 4.53337 3.57438 5.71655 3.00099 7.10083C2.4276 8.48512 2.27757 10.0084 2.56989 11.4779C2.8622 12.9475 3.58372 14.2973 4.64321 15.3568C5.7027 16.4163 7.05257 17.1378 8.52212 17.4301C9.99167 17.7225 11.5149 17.5724 12.8992 16.999C14.2835 16.4256 15.4667 15.4546 16.2991 14.2088C17.1315 12.963 17.5758 11.4983 17.5758 9.99995C17.5736 7.99142 16.7747 6.0658 15.3545 4.64555C13.9342 3.2253 12.0086 2.42643 10.0001 2.42419V2.42419ZM10.0001 16.0606C8.8014 16.0606 7.62965 15.7051 6.63298 15.0392C5.63632 14.3732 4.85952 13.4267 4.40081 12.3192C3.94209 11.2118 3.82207 9.99323 4.05592 8.81759C4.28977 7.64194 4.86699 6.56205 5.71458 5.71446C6.56217 4.86687 7.64207 4.28965 8.81771 4.0558C9.99335 3.82195 11.2119 3.94197 12.3194 4.40068C13.4268 4.8594 14.3733 5.6362 15.0393 6.63286C15.7052 7.62952 16.0607 8.80128 16.0607 9.99995C16.0588 11.6068 15.4197 13.1472 14.2835 14.2834C13.1474 15.4196 11.6069 16.0587 10.0001 16.0606V16.0606Z" fill="#666666"/>
            </svg>`;

          this.init();
        }

        init() {
          this.updateTime();
          this.fetchWeather();
          setInterval(() => this.updateTime(), 60000);
          setInterval(() => this.fetchWeather(), 1800000);
        }

        updateTime() {
          const now = new Date();
          const timeString = now.toLocaleTimeString("en-US", {
            hour: "numeric",
            minute: "2-digit",
            hour12: true,
          });
          this.timeElement.innerHTML = `${this.clockEmoji} <p>${timeString}</p>`;
        }

        async fetchWeather() {
          try {
            const apiKey = "eb6ba3ad4a6ce5ca9aeeea11b4390ca1";
            const url = `https://api.openweathermap.org/data/2.5/weather?q=${this.city},${this.state},${this.country}&units=imperial&appid=${apiKey}`;
            const response = await fetch(url);
            const data = await response.json();
            this.updateWeatherDisplay(data);
          } catch (error) {
            console.error("Error fetching weather:", error);
            this.setWeatherFallback();
          }
        }

        updateWeatherDisplay(data) {
          const temp = Math.round(data.main.temp);
          this.weatherElement.innerHTML = `${this.sunEmoji} <p>${temp}°F</p>`;
        }

        setWeatherFallback() {
          const currentHour = new Date().getHours();
          let temp;
          if (currentHour >= 6 && currentHour < 18) {
            temp = Math.floor(Math.random() * 20) + 75;
          } else {
            temp = Math.floor(Math.random() * 15) + 60;
          }
          this.weatherElement.innerHTML = `${this.sunEmoji} <p>${temp}°F</p>°`;
        }
      }

      window.addEventListener("load", function () {
        animateBioLines();
        initProjectAccordion();
        initLightbox();
        document.body.classList.add("loaded");
        new WeatherTimeManager();
      });
    </script>
  </body>
</html>
